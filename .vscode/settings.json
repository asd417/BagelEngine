{
    "cmake.configureOnOpen": true,
    "cmake.buildDirectory": "${workspaceFolder}/build",
    "cmake.generator": "Ninja Multi-Config",
    "cmake.configureArgs": [
        "-DCMAKE_C_COMPILER=clang-cl",
        "-DCMAKE_CXX_COMPILER=clang-cl",
        "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON"
    ],
    // Deliberately NOT "C_Cpp.default.configurationProvider": "ms-vscode.cmake-tools".
    // CMake marks the third-party dirs as SYSTEM includes, so clang-cl receives them as
    // -imsvc<dir>. The C/C++ extension's flag parser understands -I / /I / -isystem but not
    // -imsvc, so it drops every vendored dep (GLFW, imgui, glm, entt, Jolt, ...) and reports
    // them as missing headers. With no provider set, IntelliSense falls back to the
    // includePath in c_cpp_properties.json, which lists those dirs explicitly.
    // Keep that list in sync with the SYSTEM includes in CMakeLists.txt.

    // clang-tidy reads build/compile_commands.json (emitted by the Ninja generator), so
    // it sees the exact flags clang-cl compiles with. Config lives in .clang-tidy.
    "C_Cpp.codeAnalysis.clangTidy.enabled": true,
    "C_Cpp.codeAnalysis.runAutomatically": true,
    "C_Cpp.codeAnalysis.clangTidy.useBuildPath": true
}
